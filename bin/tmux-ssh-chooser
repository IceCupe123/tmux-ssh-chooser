#!/usr/bin/env bash

set -u

CHOOSER_PREFIX="__ssh_chooser"
CHOOSER_SESSION="${TMUX_SSH_CHOOSER_SESSION:-$CHOOSER_PREFIX}"

list_sessions() {
    printf 'new\t[Neue Session erstellen]\t\t\n'
    tmux list-sessions -F $'session\t#{session_name}\t#{session_windows}\t#{?session_attached,attached,detached}' 2>/dev/null |
        awk -F'\t' -v chooser_prefix="$CHOOSER_PREFIX" 'index($2, chooser_prefix) != 1 { print }'
}

write_sessions() {
    list_sessions > "$STATE_DIR/sessions"
}

item_count() {
    wc -l < "$STATE_DIR/sessions"
}

selected_line() {
    sed -n "$((SELECTED_INDEX + 1))p" "$STATE_DIR/sessions"
}

write_selected_target() {
    local kind name windows status

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"

    if [[ "$kind" == "new" ]]; then
        printf '__new__\n' > "$STATE_DIR/selected"
    else
        printf '%s\n' "$name" > "$STATE_DIR/selected"
    fi
}

selected_target() {
    if [[ -f "$STATE_DIR/selected" ]]; then
        <"$STATE_DIR/selected" tr -d '\n'
    else
        printf '__new__'
    fi
}

build_mode_command() {
    local mode="$1"
    shift
    local part cmd=""

    for part in "TMUX_SSH_CHOOSER_SESSION=$CHOOSER_SESSION" /bin/bash "$0" "$mode" "$@"; do
        if [[ -n "$cmd" ]]; then
            cmd+=" "
        fi
        printf -v part '%q' "$part"
        cmd+="$part"
    done

    printf '%s' "$cmd"
}

update_preview_pane() {
    local target="$1"
    local command

    if [[ -z "$target" || "$target" == '__new__' ]]; then
        command=$(build_mode_command __preview_placeholder "$STATE_DIR")
    else
        command=$(build_mode_command __preview_session "$STATE_DIR" "$target")
    fi

    tmux respawn-pane -k -t "$CHOOSER_SESSION":chooser.1 "$command" >/dev/null 2>&1
    tmux select-pane -t "$CHOOSER_SESSION":chooser.0 >/dev/null 2>&1
}

detach_preview_pane() {
    local current_command tries=0

    update_preview_pane "__new__"

    while (( tries < 20 )); do
        current_command=$(tmux display-message -p -t "$CHOOSER_SESSION":chooser.1 '#{pane_current_command}' 2>/dev/null || printf '')
        if [[ "$current_command" != "tmux" ]]; then
            break
        fi
        sleep 0.05
        tries=$((tries + 1))
    done
}

render_menu() {
    local index=0
    local kind name windows status
    local status_display

    clear
    printf 'tmux SSH Chooser\n'
    printf 'Enter = öffnen | n = nur erstellen | Ctrl-R = umbenennen | Ctrl-X = beenden | q/ESC = normale Shell\n'
    printf '\n'

    while IFS=$'\t' read -r kind name windows status; do
        if (( index == SELECTED_INDEX )); then
            tput rev
        fi

        if [[ "$kind" == "new" ]]; then
            printf '  %s\n' "$name"
        else
            case "$status" in
                attached)
                    status_display="$(tput setaf 2)[$status]$(tput sgr0)"
                    ;;
                detached)
                    status_display="$(tput setaf 3)[$status]$(tput sgr0)"
                    ;;
                *)
                    status_display="[$status]"
                    ;;
            esac
            printf '  %-24s  %3s Fenster  %s\n' "$name" "$windows" "$status_display"
        fi

        if (( index == SELECTED_INDEX )); then
            tput sgr0
        fi

        index=$((index + 1))
    done < "$STATE_DIR/sessions"

    if [[ -n "${STATUS_MESSAGE:-}" ]]; then
        printf '\n%s\n' "$STATUS_MESSAGE"
    fi
}

read_key() {
    local key next

    IFS= read -rsn1 key

    if [[ "$key" == $'\x1b' ]]; then
        if IFS= read -rsn1 -t 0.05 next; then
            key+="$next"
            if [[ ( "$next" == "[" || "$next" == "O" ) ]] && IFS= read -rsn1 -t 0.05 next; then
                key+="$next"
            fi
        fi
    fi

    printf '%s' "$key"
}

enable_raw_mode() {
    stty -echo -icanon time 0 min 1
    tput civis
}

disable_raw_mode() {
    stty sane
    tput cnorm
}

popup_prompt_line() {
    local title="$1"
    local prompt="$2"
    local initial="${3:-}"
    local result_file

    result_file="$STATE_DIR/prompt_result"
    rm -f "$result_file"

    tmux display-popup -E \
        -w 70% \
        -h 20% \
        -T "$title" \
        -e PROMPT_TEXT="$prompt" \
        -e PROMPT_INITIAL="$initial" \
        -e PROMPT_RESULT_FILE="$result_file" \
        "/bin/bash -lc 'read -e -i \"\$PROMPT_INITIAL\" -p \"\$PROMPT_TEXT\" value; printf \"%s\" \"\$value\" > \"\$PROMPT_RESULT_FILE\"'"

    if [[ -f "$result_file" ]]; then
        cat "$result_file"
        rm -f "$result_file"
    fi
}

popup_confirm() {
    local title="$1"
    local prompt="$2"
    local result_file answer

    result_file="$STATE_DIR/confirm_result"
    rm -f "$result_file"

    tmux display-popup -E \
        -w 70% \
        -h 20% \
        -T "$title" \
        -e CONFIRM_TEXT="$prompt" \
        -e CONFIRM_RESULT_FILE="$result_file" \
        "/bin/bash -lc 'printf \"%s [j/n] \" \"\$CONFIRM_TEXT\"; IFS= read -rsn1 answer; printf \"%s\" \"\$answer\" > \"\$CONFIRM_RESULT_FILE\"; printf \"\n\"'"

    if [[ -f "$result_file" ]]; then
        answer=$(cat "$result_file")
        rm -f "$result_file"
        [[ "$answer" == "j" || "$answer" == "J" || "$answer" == "y" || "$answer" == "Y" ]]
        return
    fi

    return 1
}

session_exists() {
    tmux has-session -t "=$1" 2>/dev/null
}

switch_to_session() {
    local target="$1"

    tmux switch-client -t "=$target"
    tmux kill-session -t "$CHOOSER_SESSION" >/dev/null 2>&1
    exit 0
}

create_or_open_session() {
    local target="$1"

    if session_exists "$target"; then
        switch_to_session "$target"
    else
        tmux new-session -d -s "$target" >/dev/null 2>&1
        switch_to_session "$target"
    fi
}

create_session_only() {
    local target="$1"

    if session_exists "$target"; then
        STATUS_MESSAGE="Session \"$target\" existiert bereits."
        return
    fi

    tmux new-session -d -s "$target" >/dev/null 2>&1
    STATUS_MESSAGE="Session \"$target\" erstellt."
}

rename_selected_session() {
    local kind name windows status new_name

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"
    [[ "$kind" == "session" ]] || return

    new_name=$(popup_prompt_line "Session umbenennen: $name" "Neuer Name: " "")
    new_name=${new_name:-$name}

    if [[ "$new_name" == "$name" ]]; then
        STATUS_MESSAGE=
        return
    fi

    if session_exists "$new_name"; then
        STATUS_MESSAGE="Session \"$new_name\" existiert bereits."
        return
    fi

    tmux rename-session -t "=$name" "$new_name"
    STATUS_MESSAGE=
}

kill_selected_session() {
    local kind name windows status

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"
    [[ "$kind" == "session" ]] || return

    if ! popup_confirm "Session schließen" "Wirklich Session \"$name\" schließen?"; then
        STATUS_MESSAGE=
        return
    fi

    detach_preview_pane
    tmux kill-session -t "=$name"
    STATUS_MESSAGE=
}

handle_enter() {
    local kind name windows status new_name

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"

    if [[ "$kind" == "new" ]]; then
        new_name=$(popup_prompt_line "Neue Session" "Neuer Session-Name: " "main")
        new_name=${new_name:-main}
        create_or_open_session "$new_name"
    else
        switch_to_session "$name"
    fi
}

handle_create_only() {
    local kind name windows status new_name

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"
    [[ "$kind" == "new" ]] || return

    new_name=$(popup_prompt_line "Neue Session" "Neuer Session-Name: " "main")
    new_name=${new_name:-main}
    create_session_only "$new_name"
}

menu_mode() {
    local key count current_target last_target

    STATUS_MESSAGE=
    SELECTED_INDEX=0
    last_target=''

    enable_raw_mode
    trap 'disable_raw_mode' EXIT

    while true; do
        write_sessions
        count=$(item_count)

        if (( count <= 0 )); then
            SELECTED_INDEX=0
        elif (( SELECTED_INDEX >= count )); then
            SELECTED_INDEX=$((count - 1))
        fi

        write_selected_target
        current_target=$(selected_target)
        if [[ "$current_target" != "$last_target" ]]; then
            update_preview_pane "$current_target"
            last_target="$current_target"
        fi
        last_target="$current_target"
        render_menu

        key=$(read_key)

        case "$key" in
            $'\x1b[A'|$'\x1bOA')
                (( SELECTED_INDEX > 0 )) && SELECTED_INDEX=$((SELECTED_INDEX - 1))
                ;;
            $'\x1b[B'|$'\x1bOB')
                (( SELECTED_INDEX + 1 < count )) && SELECTED_INDEX=$((SELECTED_INDEX + 1))
                ;;
            $'\x1b')
                tmux detach-client -s "$CHOOSER_SESSION" >/dev/null 2>&1
                exit 0
                ;;
            ''|$'\n'|$'\r')
                handle_enter
                ;;
            n|N)
                handle_create_only
                write_sessions
                count=$(item_count)
                if (( SELECTED_INDEX >= count )); then
                    SELECTED_INDEX=$((count - 1))
                fi
                write_selected_target
                current_target=$(selected_target)
                update_preview_pane "$current_target"
                last_target="$current_target"
                ;;
            q|Q)
                tmux detach-client -s "$CHOOSER_SESSION" >/dev/null 2>&1
                exit 0
                ;;
            k|K)
                (( SELECTED_INDEX > 0 )) && SELECTED_INDEX=$((SELECTED_INDEX - 1))
                ;;
            j|J)
                (( SELECTED_INDEX + 1 < count )) && SELECTED_INDEX=$((SELECTED_INDEX + 1))
                ;;
            $'\x12')
                rename_selected_session
                ;;
            $'\x18')
                kill_selected_session
                write_sessions
                count=$(item_count)
                if (( count == 1 )); then
                    STATUS_MESSAGE='Keine Sessions vorhanden. Wähle "[Neue Session erstellen]".'
                    SELECTED_INDEX=0
                elif (( SELECTED_INDEX >= count )); then
                    SELECTED_INDEX=$((count - 1))
                fi
                write_selected_target
                current_target=$(selected_target)
                update_preview_pane "$current_target"
                last_target="$current_target"
                ;;
        esac
    done
}

preview_placeholder_mode() {
    clear
    printf '[Neue Session erstellen]\n'
    printf '\n'
    printf 'Enter: neue Session anlegen und direkt öffnen\n'
    printf 'n: neue Session nur anlegen und im Chooser bleiben\n'
    printf 'Default-Name: main\n'
    printf '\n'
    printf 'Ctrl-R: markierte Session umbenennen\n'
    printf 'Ctrl-X: markierte Session beenden\n'
    printf 'q oder ESC: zurück zur normalen Shell\n'

    while :; do
        sleep 3600
    done
}

preview_session_mode() {
    local target="$1"

    unset TMUX
    exec tmux attach-session -r -t "=$target"
}

main_mode() {
    local script_path

    STATE_DIR=$(mktemp -d /tmp/tmux-ssh-chooser.XXXXXX)
    script_path="$0"
    CHOOSER_SESSION="${CHOOSER_PREFIX}_$$"

    tmux kill-session -t "$CHOOSER_SESSION" >/dev/null 2>&1

    tmux new-session -d -s "$CHOOSER_SESSION" -n chooser "$(build_mode_command __menu "$STATE_DIR")"
    tmux split-window -h -l 60% -t "$CHOOSER_SESSION":chooser "$(build_mode_command __preview_placeholder "$STATE_DIR")"
    tmux set-option -t "$CHOOSER_SESSION" status off >/dev/null 2>&1
    tmux select-layout -t "$CHOOSER_SESSION":chooser even-horizontal >/dev/null 2>&1
    tmux select-pane -t "$CHOOSER_SESSION":chooser.0 >/dev/null 2>&1
    tmux bind-key -n C-r if-shell -F '#{m:^__ssh_chooser,#{session_name}}' \
        "send-keys -t '#{session_name}:chooser.0' C-r" \
        "send-keys C-r"
    tmux bind-key -n C-x if-shell -F '#{m:^__ssh_chooser,#{session_name}}' \
        "send-keys -t '#{session_name}:chooser.0' C-x" \
        "send-keys C-x"

    tmux attach-session -t "$CHOOSER_SESSION"

    tmux unbind-key -n C-r >/dev/null 2>&1
    tmux unbind-key -n C-x >/dev/null 2>&1
    tmux kill-session -t "$CHOOSER_SESSION" >/dev/null 2>&1
    rm -rf "$STATE_DIR"
}

MODE="${1:-__main}"

case "$MODE" in
    __menu)
        STATE_DIR="$2"
        menu_mode
        ;;
    __preview_placeholder)
        STATE_DIR="$2"
        preview_placeholder_mode
        ;;
    __preview_session)
        STATE_DIR="$2"
        preview_session_mode "$3"
        ;;
    __main)
        main_mode
        ;;
esac
