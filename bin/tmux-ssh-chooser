status_created() { printf 'Session "%s" %s.' "$1" "$(txt created_word)"; }
status_exists() { printf 'Session "%s" %s.' "$1" "$(txt exists_word)"; }
status_no_sessions() { printf '%s "%s".' "$(txt no_sessions_prefix)" "$(txt entry_new)"; }
confirm_close_text() { printf '%s "%s" %s?' "$(txt really_close_prefix)" "$1" "$(txt really_close_suffix)"; }
rename_title() { printf '%s: %s' "$(txt rename_title_prefix)" "$1"; }
language_display() { printf '%s' "$CHOOSER_LANG"; }

status_with_reason() {
    local prefix_key="$1"
    local session_name="$2"
    local reason="${3:-}"
    local fmt msg

    fmt=$(txt "$prefix_key")
    # shellcheck disable=SC2059
    printf -v msg "$fmt" "$session_name"

    if [[ -n "$reason" ]]; then
        printf '%s: %s.' "$msg" "$reason"
    else
        printf '%s.' "$msg"
    fi
}

status_create_failed() { status_with_reason create_failed_prefix "$1" "${2:-}"; }
status_rename_failed() { status_with_reason rename_failed_prefix "$1" "${2:-}"; }
status_close_failed() { status_with_reason close_failed_prefix "$1" "${2:-}"; }
status_invalid_name() { status_with_reason invalid_name_prefix "$1" "$(txt invalid_name_reason)"; }

is_valid_session_name() {
    local name="$1"
    [[ -n "$name" && ! "$name" =~ [:.] ]]
}

read_menu_context() {
    if [[ -f "$STATE_DIR/context" ]]; then
        MENU_CONTEXT=$(<"$STATE_DIR/context")
    else
        MENU_CONTEXT="root"
    fi
}

write_menu_context() {
    printf '%s\n' "$MENU_CONTEXT" > "$STATE_DIR/context"
}

enter_settings_menu() {
    MENU_CONTEXT="settings"
    SELECTED_INDEX=0
    write_menu_context
}

enter_language_menu() {
    MENU_CONTEXT="language"
    SELECTED_INDEX=0
    write_menu_context
}

leave_settings_menu() {
    MENU_CONTEXT="root"
    SELECTED_INDEX=1
    write_menu_context
}

leave_language_menu() {
    MENU_CONTEXT="settings"
    SELECTED_INDEX=0
    write_menu_context
}

session_display_status() {
    local session_name="$1"

    if tmux list-clients -t "=$session_name" -F '#{client_flags}' 2>/dev/null | \
        awk '!/read-only/ { found=1 } END { exit(found ? 0 : 1) }'
    then
        printf 'attached'
    else
        printf 'detached'
    fi
}

sort_sessions() {
    case "${SORT_MODE:-name}" in
        created)
            LC_ALL=C sort -t$'\t' -k1 -rn
            ;;
        attached)
            LC_ALL=C awk -F$'\t' -v OFS=$'\t' -v snap="$STATE_DIR/last_attached" '
                BEGIN { while ((getline line < snap) > 0) { split(line, a, FS); ts[a[1]] = a[2] } }
                { $2 = (ts[$3] != "" ? ts[$3] : "0"); print }
            ' | LC_ALL=C sort -t$'\t' -k2 -rn
            ;;
        *)
            LC_ALL=C sort -t$'\t' -k3
            ;;
    esac
}

list_items() {
    local name windows status

    read_menu_context

    if [[ "$MENU_CONTEXT" == "language" ]]; then
        printf 'lang_de\t%s\t\t\n' "$(txt entry_lang_de)"
        printf 'lang_en\t%s\t\t\n' "$(txt entry_lang_en)"
        printf 'lang_ru\t%s\t\t\n' "$(txt entry_lang_ru)"
        printf 'back_settings\t%s\t\t\n' "$(txt entry_back)"
        return
    fi

    if [[ "$MENU_CONTEXT" == "settings" ]]; then
        printf 'language\t%s\t\t\n' "$(txt entry_language)"
        printf 'back\t%s\t\t\n' "$(txt entry_back)"
        return
    fi

    printf 'settings\t%s\t\t\n' "$(txt entry_settings)"
    printf 'new\t%s\t\t\n' "$(txt entry_new)"

    local fav_lines="" nonfav_lines=""
    local _c _a name windows status
    while IFS=$'\t' read -r _c _a name windows; do
        [[ -z "$name" ]] && continue
        [[ "$name" == "$CHOOSER_PREFIX"* ]] && continue
        status=$(session_display_status "$name")
        if is_favorite "$name"; then
            fav_lines+=$'session\t'"$name"$'\t'"$windows"$'\t'"$status"$'\n'
        else
            nonfav_lines+=$'session\t'"$name"$'\t'"$windows"$'\t'"$status"$'\n'
        fi
    done < <(tmux list-sessions \
        -F $'#{session_created}\t#{?session_last_attached,#{session_last_attached},0}\t#{session_name}\t#{session_windows}' \
        2>/dev/null | sort_sessions)

    printf '%s' "$fav_lines"
    printf '%s' "$nonfav_lines"
}

write_items() {
    list_items > "$STATE_DIR/sessions"
}

item_count() {
    wc -l < "$STATE_DIR/sessions"
}

selected_line() {
    sed -n "$((SELECTED_INDEX + 1))p" "$STATE_DIR/sessions"
}

write_selected_target() {
    local kind name windows status

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"

    if [[ "$kind" == "new" ]]; then
        printf '__new__\n' > "$STATE_DIR/selected"
    elif [[ "$kind" == "settings" ]]; then
        printf '__settings__\n' > "$STATE_DIR/selected"
    elif [[ "$kind" == "language" ]]; then
        printf '__language__\n' > "$STATE_DIR/selected"
    elif [[ "$kind" == "lang_de" ]]; then
        printf '__lang_de__\n' > "$STATE_DIR/selected"
    elif [[ "$kind" == "lang_en" ]]; then
        printf '__lang_en__\n' > "$STATE_DIR/selected"
    elif [[ "$kind" == "lang_ru" ]]; then
        printf '__lang_ru__\n' > "$STATE_DIR/selected"
    elif [[ "$kind" == "back" ]]; then
        printf '__back__\n' > "$STATE_DIR/selected"
    elif [[ "$kind" == "back_settings" ]]; then
        printf '__back_settings__\n' > "$STATE_DIR/selected"
    else
        printf '%s\n' "$name" > "$STATE_DIR/selected"
    fi
}

selected_target() {
    if [[ -f "$STATE_DIR/selected" ]]; then
        <"$STATE_DIR/selected" tr -d '\n'
    else
        printf '__new__'
    fi
}

build_mode_command() {
    local mode="$1"
    shift
    local part cmd=""

    for part in "TMUX_SSH_CHOOSER_SESSION=$CHOOSER_SESSION" /bin/bash "$0" "$mode" "$@"; do
        if [[ -n "$cmd" ]]; then
            cmd+=" "
        fi
        printf -v part '%q' "$part"
        cmd+="$part"
    done

    printf '%s' "$cmd"
}

update_preview_pane() {
    local target="$1"
    local command

    if [[ "$target" == '__settings__' ]]; then
        command=$(build_mode_command __preview_settings "$STATE_DIR")
    elif [[ "$target" == '__language__' ]]; then
        command=$(build_mode_command __preview_language "$STATE_DIR")
    elif [[ "$target" == '__lang_de__' ]]; then
        command=$(build_mode_command __preview_language_choice "$STATE_DIR" de)
    elif [[ "$target" == '__lang_en__' ]]; then
        command=$(build_mode_command __preview_language_choice "$STATE_DIR" en)
    elif [[ "$target" == '__lang_ru__' ]]; then
        command=$(build_mode_command __preview_language_choice "$STATE_DIR" ru)
    elif [[ "$target" == '__back__' ]]; then
        command=$(build_mode_command __preview_back "$STATE_DIR")
    elif [[ "$target" == '__back_settings__' ]]; then
        command=$(build_mode_command __preview_back_settings "$STATE_DIR")
    elif [[ -z "$target" || "$target" == '__new__' ]]; then
        command=$(build_mode_command __preview_placeholder "$STATE_DIR")
    else
        command=$(build_mode_command __preview_session "$STATE_DIR" "$target")
    fi

    tmux respawn-pane -k -t "$CHOOSER_SESSION":chooser.1 "$command" >/dev/null 2>&1
    tmux select-pane -t "$CHOOSER_SESSION":chooser.0 >/dev/null 2>&1
}

detach_preview_pane() {
    local current_command tries=0

    update_preview_pane "__new__"

    while (( tries < 20 )); do
        current_command=$(tmux display-message -p -t "$CHOOSER_SESSION":chooser.1 '#{pane_current_command}' 2>/dev/null || printf '')
        if [[ "$current_command" != "tmux" ]]; then
            break
        fi
        sleep 0.05
        tries=$((tries + 1))
    done
}

ui_init() {
    UI_RESET="$(tput sgr0)"
    UI_BOLD="$(tput bold)"
    UI_DIM="$(tput dim)"
    UI_CYAN="$(tput setaf 6)"
    UI_GREEN="$(tput setaf 2)"
    UI_YELLOW="$(tput setaf 3)"
    UI_RED="$(tput setaf 1)"
    UI_BLUE="$(tput setaf 4)"
}

ui_rule() {
    local char="${1:--}"
    local width

    width=$(tput cols 2>/dev/null || printf '80')
    (( width > 72 )) && width=72
    printf '%*s\n' "$width" '' | tr ' ' "$char"
}

ui_badge() {
    local color="$1"
    local text="$2"

    printf '%s[%s]%s' "$color" "$text" "$UI_RESET"
}

render_menu() {
    local index=0
    local kind name windows status selected_kind
    local status_display marker line_name line_windows special_badge
    local row_prefix row_name_color num_prefix _snum=0 _seen_fav=0 _seen_nonfav=0 _is_fav
    local status_prefix display_name term_width name_width fill fill_str sort_label
    local item_prefix

    read_menu_context
    IFS=$'\t' read -r selected_kind _ <<< "$(selected_line)"
    term_width=$(tput cols 2>/dev/null || printf '80')
    (( term_width > 72 )) && term_width=72
    name_width=$(( term_width - 30 ))
    (( name_width < 12 )) && name_width=12

    clear
    if [[ "$MENU_CONTEXT" == "language" ]]; then
        printf '%s%s%s%s\n' "$UI_BOLD" "$UI_CYAN" "$(txt language_menu_title)" "$UI_RESET"
    elif [[ "$MENU_CONTEXT" == "settings" ]]; then
        printf '%s%s%s%s\n' "$UI_BOLD" "$UI_CYAN" "$(txt settings_menu_title)" "$UI_RESET"
    else
        case "${SORT_MODE:-name}" in
            created)  sort_label=$(txt sort_created) ;;
            attached) sort_label=$(txt sort_attached) ;;
            *)        sort_label=$(txt sort_name) ;;
        esac
        printf '%s%s%s%s  %s[%s: %s]%s\n' \
            "$UI_BOLD" "$UI_CYAN" "$(txt menu_title)" "$UI_RESET" \
            "$UI_DIM" "$(txt sort_key)" "$sort_label" "$UI_RESET"
    fi
    ui_rule "─"
    if [[ "$selected_kind" == "new" ]]; then
        printf '%sEnter%s %s  %s•%s  %sn%s %s  %s•%s  %sCtrl-R%s %s  %s•%s  %sCtrl-X%s %s  %s•%s  %sq/ESC/BS%s %s\n' \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt open)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt create_only)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt rename)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt close)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt shell)"
    elif [[ "$selected_kind" == "settings" ]]; then
        printf '%s%s%s  %s•%s  %sCtrl-R%s %s  %s•%s  %sCtrl-X%s %s  %s•%s  %sq/ESC/BS%s %s\n' \
            "$UI_BOLD" "Enter  $(txt settings_open)" "$UI_RESET" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt rename)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt close)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt shell)"
    elif [[ "$selected_kind" == "language" ]]; then
        printf '%s%s%s  %s•%s  %sq/ESC/BS%s %s\n' \
            "$UI_BOLD" "$(txt language_enter)" "$UI_RESET" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt back_action)"
    elif [[ "$selected_kind" == "lang_de" || "$selected_kind" == "lang_en" || "$selected_kind" == "lang_ru" ]]; then
        printf '%s%s%s  %s•%s  %sq/ESC/BS%s %s\n' \
            "$UI_BOLD" "$(txt language_apply)" "$UI_RESET" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt back_action)"
    elif [[ "$selected_kind" == "back" ]]; then
        printf '%sEnter%s %s  %s•%s  %sq/ESC/BS%s %s\n' \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt back_action)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt back_action)"
    elif [[ "$selected_kind" == "back_settings" ]]; then
        printf '%sEnter%s %s  %s•%s  %sq/ESC/BS%s %s\n' \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt back_action)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt back_action)"
    else
        printf '%sEnter%s %s  %s•%s  %sCtrl-R%s %s  %s•%s  %sCtrl-X%s %s  %s•%s  %sf%s %s  %s•%s  %ss%s %s  %s•%s  %sq/ESC/BS%s %s\n' \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt open)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt rename)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt close)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt favorite)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt sort_key)" \
            "$UI_DIM" "$UI_RESET" \
            "$UI_BOLD" "$UI_RESET" \
            "$(txt shell)"
    fi
    printf '\n'

    while IFS=$'\t' read -r kind name windows status; do
        _is_fav=0
        [[ "$kind" == "session" ]] && is_favorite "$name" && _is_fav=1

        if [[ $index -eq 0 ]]; then
            printf '%s%s%s\n' "$UI_BOLD" "$(txt section_action)" "$UI_RESET"
        elif [[ "$MENU_CONTEXT" == "root" && "$kind" == "session" ]]; then
            if (( _is_fav )); then
                if (( _seen_fav == 0 )); then
                    printf '\n'
                    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_favorites)" "$UI_RESET"
                    _seen_fav=1
                fi
            else
                if (( _seen_nonfav == 0 )); then
                    printf '\n'
                    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_sessions)" "$UI_RESET"
                    _seen_nonfav=1
                fi
            fi
        fi

        if [[ "$kind" == "new" || "$kind" == "settings" || "$kind" == "language" || "$kind" == "back" || "$kind" == "lang_de" || "$kind" == "lang_en" || "$kind" == "lang_ru" || "$kind" == "back_settings" ]]; then
            if [[ "$kind" == "settings" ]]; then
                special_badge=""
            elif [[ "$kind" == "language" ]]; then
                special_badge="$(ui_badge "$UI_CYAN" "lang")"
            elif [[ "$kind" == "lang_de" ]]; then
                special_badge="$(ui_badge "$UI_CYAN" "de")"
            elif [[ "$kind" == "lang_en" ]]; then
                special_badge="$(ui_badge "$UI_CYAN" "en")"
            elif [[ "$kind" == "lang_ru" ]]; then
                special_badge="$(ui_badge "$UI_CYAN" "ru")"
            elif [[ "$kind" == "back_settings" ]]; then
                special_badge="$(ui_badge "$UI_DIM" "<")"
            elif [[ "$kind" == "back" ]]; then
                special_badge="$(ui_badge "$UI_DIM" "<")"
            else
                special_badge=""
            fi
            if (( index == SELECTED_INDEX )); then
                item_prefix="${UI_BOLD}${UI_CYAN}›${UI_RESET}"
                if [[ -n "$special_badge" ]]; then
                    printf '%s  %s  %s%s%s\n' \
                        "$item_prefix" \
                        "$special_badge" \
                        "$UI_BOLD" "$name" "$UI_RESET"
                else
                    printf '%s  %s%s%s\n' \
                        "$item_prefix" \
                        "$UI_BOLD" "$name" "$UI_RESET"
                fi
            else
                item_prefix="  "
                if [[ -n "$special_badge" ]]; then
                    printf '%s  %s  %s%s%s\n' \
                        "$item_prefix" \
                        "$special_badge" \
                        "$UI_BLUE" "$name" "$UI_RESET"
                else
                    printf '%s  %s%s%s\n' \
                        "$item_prefix" \
                        "$UI_BLUE" "$name" "$UI_RESET"
                fi
            fi
        else
            case "$status" in
                attached)
                    status_display="$(ui_badge "$UI_GREEN" "$(txt status_attached)")"
                    ;;
                detached)
                    status_display="$(ui_badge "$UI_YELLOW" "$(txt status_detached)")"
                    ;;
                *)
                    status_display="[$status]"
                    ;;
            esac
            _snum=$(( _snum + 1 ))
            if   (( _snum <= 9 ));  then num_prefix="${_snum} "
            elif (( _snum == 10 )); then num_prefix="0 "
            else                         num_prefix="  "
            fi
            if (( _is_fav )); then
                row_name_color="${UI_BOLD}${UI_YELLOW}"
            elif (( index == SELECTED_INDEX )); then
                row_name_color="$UI_BOLD"
            else
                row_name_color="$UI_RESET"
            fi
            display_name="${num_prefix}${name}"
            if (( ${#display_name} > name_width )); then
                display_name="${display_name:0:$(( name_width - 1 ))}…"
            fi
            printf -v line_windows '%2s %s' "$windows" "$(txt windows)"
            # 12 = 2 spaces before status + 10 visible chars of "[attached]"/"[detached]"
            fill=$(( term_width - 4 - name_width - ${#line_windows} - 12 ))
            (( fill < 1 )) && fill=1
            printf -v fill_str '%*s' "$fill" ''
            printf -v line_name "%-${name_width}s" "$display_name"
            row_prefix="${UI_DIM}│${UI_RESET}"
            if (( index == SELECTED_INDEX )); then
                marker="${UI_BOLD}${UI_CYAN}›${UI_RESET}"
                printf '%s %s %s%s%s%s%s%s%s  %s\n' \
                    "$marker" \
                    "$row_prefix" \
                    "$row_name_color" "$line_name" "$UI_RESET" \
                    "$fill_str" \
                    "$UI_DIM" "$line_windows" "$UI_RESET" \
                    "$status_display"
            else
                printf '  %s %s%s%s%s%s%s%s  %s\n' \
                    "$row_prefix" \
                    "$row_name_color" "$line_name" "$UI_RESET" \
                    "$fill_str" \
                    "$UI_DIM" "$line_windows" "$UI_RESET" \
                    "$status_display"
            fi
        fi

        index=$((index + 1))
    done < "$STATE_DIR/sessions"

    if [[ -n "${STATUS_MESSAGE:-}" ]]; then
        if [[ "$STATUS_MESSAGE" == *"$(txt created_word)." ]]; then
            status_prefix="${UI_BOLD}${UI_GREEN} $(txt label_ok) ${UI_RESET}"
        elif [[ "$STATUS_MESSAGE" == *"$(txt exists_word)." ]]; then
            status_prefix="${UI_BOLD}${UI_YELLOW} $(txt label_note) ${UI_RESET}"
        else
            status_prefix="${UI_BOLD}${UI_BLUE} $(txt label_info) ${UI_RESET}"
        fi
        printf '\n%s %s%s%s\n' "$status_prefix" "$UI_DIM" "$STATUS_MESSAGE" "$UI_RESET"
    fi
}

read_key() {
    local key next

    IFS= read -rsn1 key

    if [[ "$key" == $'\x1b' ]]; then
        if IFS= read -rsn1 -t 0.05 next; then
            key+="$next"
            if [[ ( "$next" == "[" || "$next" == "O" ) ]] && IFS= read -rsn1 -t 0.05 next; then
                key+="$next"
            fi
        fi
    fi

    printf '%s' "$key"
}

enable_raw_mode() {
    stty -echo -icanon time 0 min 1
    tput civis
}

disable_raw_mode() {
    stty sane
    tput cnorm
}

popup_prompt_line() {
    local title="$1"
    local prompt="$2"
    local initial="${3:-}"
    local result_file

    result_file="$STATE_DIR/prompt_result"
    rm -f "$result_file"

    tmux display-popup -E \
        -w 70% \
        -h 20% \
        -T "$title" \
        -e PROMPT_TEXT="$prompt" \
        -e PROMPT_INITIAL="$initial" \
        -e PROMPT_RESULT_FILE="$result_file" \
        "/bin/bash -lc '
            value=\$PROMPT_INITIAL
            replaced=0
            printf \"%s%s\" \"\$PROMPT_TEXT\" \"\$value\"
            stty -echo -icanon time 0 min 1
            trap \"stty sane\" EXIT

            while IFS= read -rsn1 key; do
                case \"\$key\" in
                    \"\"|$'\''\n'\''|$'\''\r'\'')
                        break
                        ;;
                    $'\''\x1b'\'')
                        printf \"\n\"
                        exit 0
                        ;;
                    $'\''\177'\''|$'\''\b'\'')
                        if [[ -n \"\$value\" ]]; then
                            value=\${value%?}
                            printf \"\b \b\"
                        fi
                        ;;
                    $'\''\t'\'')
                        ;;
                    *)
                        if (( replaced == 0 )) && [[ -n \"\$PROMPT_INITIAL\" ]]; then
                            while [[ -n \"\$value\" ]]; do
                                value=\${value%?}
                                printf \"\b \b\"
                            done
                            replaced=1
                        fi
                        value+=\$key
                        printf \"%s\" \"\$key\"
                        ;;
                esac
            done

            stty sane
            trap - EXIT
            printf \"%s\" \"\$value\" > \"\$PROMPT_RESULT_FILE\"
            printf \"\n\"
        '"

    if [[ -f "$result_file" ]]; then
        cat "$result_file"
        rm -f "$result_file"
        return 0
    fi

    return 1
}

popup_confirm() {
    local title="$1"
    local prompt="$2"
    local result_file answer

    result_file="$STATE_DIR/confirm_result"
    rm -f "$result_file"

    tmux display-popup -E \
        -w 70% \
        -h 30% \
        -T "$title" \
        -e CONFIRM_TEXT="$prompt" \
        -e CONFIRM_RESULT_FILE="$result_file" \
        -e CONFIRM_TITLE="$title" \
        -e CONFIRM_HINTS="$(txt confirm_hints)" \
        -e CONFIRM_YES_LINE="$(txt confirm_yes_line)" \
        -e CONFIRM_NO_LINE="$(txt confirm_no_line)" \
        "/bin/bash -lc '
            read_key() {
                local key next

                IFS= read -rsn1 key
                if [[ \"\$key\" == \$'\''\x1b'\'' ]]; then
                    if IFS= read -rsn1 -t 0.05 next; then
                        key+=\$next
                        if [[ ( \"\$next\" == \"[\" || \"\$next\" == \"O\" ) ]] && IFS= read -rsn1 -t 0.05 next; then
                            key+=\$next
                        fi
                    fi
                fi

                printf \"%s\" \"\$key\"
            }

            render_dialog() {
                local reset bold dim cyan green yellow
                local yes_marker no_marker yes_style no_style

                reset=\$(tput sgr0)
                bold=\$(tput bold)
                dim=\$(tput dim)
                cyan=\$(tput setaf 6)
                green=\$(tput setaf 2)
                yellow=\$(tput setaf 3)

                clear
                printf \"%s%s%s%s\n\" \"\$bold\" \"\$cyan\" \"\$CONFIRM_TITLE\" \"\$reset\"
                printf \"%*s\n\" 56 \"\" | tr \" \" \"-\"
                printf \"%s%s%s\n\n\" \"\$bold\" \"\$CONFIRM_HINTS\" \"\$reset\"
                printf \"%s\n\n\" \"\$CONFIRM_TEXT\"

                if [[ \"\$selected\" == \"yes\" ]]; then
                    yes_marker=\"\${bold}\${cyan}›\${reset}\"
                    no_marker=\" \"
                    yes_style=\"\${bold}\${green}\"
                    no_style=\"\${reset}\"
                else
                    yes_marker=\" \"
                    no_marker=\"\${bold}\${cyan}›\${reset}\"
                    yes_style=\"\${reset}\"
                    no_style=\"\${bold}\${yellow}\"
                fi

                printf \"%s  %s%s%s\n\" \"\$yes_marker\" \"\$yes_style\" \"\$CONFIRM_YES_LINE\" \"\$reset\"
                printf \"%s  %s%s%s\n\" \"\$no_marker\" \"\$no_style\" \"\$CONFIRM_NO_LINE\" \"\$reset\"
            }

            selected=no
            tput civis
            stty -echo -icanon time 0 min 1
            trap \"stty sane; tput cnorm\" EXIT

            while :; do
                render_dialog
                answer=\$(read_key)
                case \"\$answer\" in
                    y|Y|j|J)
                        printf \"Y\" > \"\$CONFIRM_RESULT_FILE\"
                        break
                        ;;
                    n|N|$'\''\x1b'\'')
                        printf \"N\" > \"\$CONFIRM_RESULT_FILE\"
                        break
                        ;;
                    \"\"|$'\''\n'\''|$'\''\r'\'')
                        if [[ \"\$selected\" == \"yes\" ]]; then
                            printf \"Y\" > \"\$CONFIRM_RESULT_FILE\"
                        else
                            printf \"N\" > \"\$CONFIRM_RESULT_FILE\"
                        fi
                        break
                        ;;
                    $'\''\x1b[D'\''|$'\''\x1b[A'\''|h|H|k|K)
                        selected=yes
                        ;;
                    $'\''\x1b[C'\''|$'\''\x1b[B'\''|l|L)
                        selected=no
                        ;;
                esac
            done

            stty sane
            tput cnorm
            trap - EXIT
        '"

    if [[ -f "$result_file" ]]; then
        answer=$(cat "$result_file")
        rm -f "$result_file"
        [[ "$answer" == "j" || "$answer" == "J" || "$answer" == "y" || "$answer" == "Y" ]]
        return
    fi

    return 1
}

load_favorites() {
    FAVORITES=()
    [[ -f "$CONFIG_DIR/favorites" ]] || return
    while IFS= read -r _fav; do
        [[ -n "$_fav" ]] && FAVORITES+=("$_fav")
    done < "$CONFIG_DIR/favorites"
}

save_favorites() {
    mkdir -p "$CONFIG_DIR"
    if (( ${#FAVORITES[@]} == 0 )); then
        rm -f "$CONFIG_DIR/favorites"
        return
    fi
    printf '%s\n' "${FAVORITES[@]}" > "$CONFIG_DIR/favorites"
}

is_favorite() {
    local _name="$1" _fav
    for _fav in "${FAVORITES[@]+"${FAVORITES[@]}"}"; do
        [[ "$_fav" == "$_name" ]] && return 0
    done
    return 1
}

toggle_favorite() {
    local kind name windows status
    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"
    [[ "$kind" == "session" ]] || return

    local _new=() _found=0 _fav
    for _fav in "${FAVORITES[@]+"${FAVORITES[@]}"}"; do
        if [[ "$_fav" == "$name" ]]; then
            _found=1
        else
            _new+=("$_fav")
        fi
    done
    (( _found == 0 )) && _new+=("$name")
    FAVORITES=("${_new[@]+"${_new[@]}"}")
    save_favorites
}

rename_favorite() {
    local old_name="$1"
    local new_name="$2"
    local _fav _updated=()

    is_favorite "$old_name" || return

    for _fav in "${FAVORITES[@]+"${FAVORITES[@]}"}"; do
        if [[ "$_fav" == "$old_name" ]]; then
            _updated+=("$new_name")
        else
            _updated+=("$_fav")
        fi
    done

    FAVORITES=("${_updated[@]+"${_updated[@]}"}")
    save_favorites
}

session_exists() {
    tmux has-session -t "=$1" 2>/dev/null
}

random_session_name() {
    local adjectives=(cold dark swift bright deep vast lone pale wild bold
                      dim lost far dead twin iron ash void calm faint
                      blue dry raw hot dusk dawn)
    local bodies=(nova comet pulsar quasar nebula vega lyra orion cygnus
                  draco hydra ara crux vela auriga pavo lupus indus antlia)
    local adj body name tries=0

    while (( tries < 20 )); do
        adj=${adjectives[$RANDOM % ${#adjectives[@]}]}
        body=${bodies[$RANDOM % ${#bodies[@]}]}
        name="$adj-$body"
        tmux has-session -t "=$name" 2>/dev/null || { printf '%s' "$name"; return; }
        tries=$(( tries + 1 ))
    done

    printf '%s-%d' "$name" "$RANDOM"
}

switch_to_session() {
    local target="$1"

    tmux switch-client -t "=$target"
    tmux kill-session -t "$CHOOSER_SESSION" >/dev/null 2>&1
    exit 0
}

create_or_open_session() {
    local target="$1"
    local err

    if ! is_valid_session_name "$target"; then
        STATUS_MESSAGE="$(status_invalid_name "$target")"
        return 1
    fi

    if session_exists "$target"; then
        switch_to_session "$target"
    else
        if ! err=$(tmux new-session -d -s "$target" 2>&1 >/dev/null); then
            STATUS_MESSAGE="$(status_create_failed "$target" "$err")"
            return 1
        fi
        switch_to_session "$target"
    fi
}

create_session_only() {
    local target="$1"
    local err

    if ! is_valid_session_name "$target"; then
        STATUS_MESSAGE="$(status_invalid_name "$target")"
        return 1
    fi

    if session_exists "$target"; then
        STATUS_MESSAGE="$(status_exists "$target")"
        return 1
    fi

    if ! err=$(tmux new-session -d -s "$target" 2>&1 >/dev/null); then
        STATUS_MESSAGE="$(status_create_failed "$target" "$err")"
        return 1
    fi
    STATUS_MESSAGE="$(status_created "$target")"
}

rename_selected_session() {
    local kind name windows status new_name err

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"
    [[ "$kind" == "session" ]] || return

    new_name=$(popup_prompt_line "$(rename_title "$name")" "$(txt prompt_rename_name)" "$name") || return
    new_name=${new_name:-$name}

    if [[ "$new_name" == "$name" ]]; then
        STATUS_MESSAGE=
        return
    fi

    if ! is_valid_session_name "$new_name"; then
        STATUS_MESSAGE="$(status_invalid_name "$new_name")"
        return 1
    fi

    if session_exists "$new_name"; then
        STATUS_MESSAGE="$(status_exists "$new_name")"
        return 1
    fi

    if ! err=$(tmux rename-session -t "=$name" "$new_name" 2>&1 >/dev/null); then
        STATUS_MESSAGE="$(status_rename_failed "$name" "$err")"
        return 1
    fi
    rename_favorite "$name" "$new_name"
    STATUS_MESSAGE=
}

kill_selected_session() {
    local kind name windows status err

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"
    [[ "$kind" == "session" ]] || return

    if ! popup_confirm "$(txt confirm_close_title)" "$(confirm_close_text "$name")"; then
        STATUS_MESSAGE=
        return
    fi

    detach_preview_pane
    if ! err=$(tmux kill-session -t "=$name" 2>&1 >/dev/null); then
        STATUS_MESSAGE="$(status_close_failed "$name" "$err")"
        return 1
    fi
    STATUS_MESSAGE=
}

handle_enter() {
    local kind name windows status new_name

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"

    if [[ "$kind" == "settings" ]]; then
        enter_settings_menu
    elif [[ "$kind" == "language" ]]; then
        enter_language_menu
    elif [[ "$kind" == "lang_de" ]]; then
        handle_settings de
    elif [[ "$kind" == "lang_en" ]]; then
        handle_settings en
    elif [[ "$kind" == "lang_ru" ]]; then
        handle_settings ru
    elif [[ "$kind" == "back" ]]; then
        leave_settings_menu
    elif [[ "$kind" == "back_settings" ]]; then
        leave_language_menu
    elif [[ "$kind" == "new" ]]; then
        new_name=$(popup_prompt_line "$(txt prompt_new_title)" "$(txt prompt_new_name)" "") || return
        new_name=${new_name:-$(random_session_name)}
        create_or_open_session "$new_name"
    else
        switch_to_session "$name"
    fi
}

handle_create_only() {
    local kind name windows status new_name

    IFS=$'\t' read -r kind name windows status <<< "$(selected_line)"
    [[ "$kind" == "new" ]] || return

    new_name=$(popup_prompt_line "$(txt prompt_new_title)" "$(txt prompt_new_name)" "") || return
    new_name=${new_name:-$(random_session_name)}
    create_session_only "$new_name"
}

handle_settings() {
    local new_lang="${1:-}"

    [[ -n "$new_lang" ]] || return

    CHOOSER_LANG="$new_lang"
    save_config
    STATUS_MESSAGE="$(txt language_saved)"
    write_items
}

snapshot_last_attached() {
    tmux list-sessions \
        -F $'#{session_name}\t#{?session_last_attached,#{session_last_attached},0}' \
        2>/dev/null > "$STATE_DIR/last_attached" || true
}

menu_mode() {
    local key count current_target last_target _num_idx _sidx _lidx _kind _rest

    STATUS_MESSAGE=
    SELECTED_INDEX=1
    last_target=''
    load_favorites
    snapshot_last_attached
    write_menu_context
    ui_init

    enable_raw_mode
    trap 'disable_raw_mode' EXIT

    while true; do
        write_items
        count=$(item_count)

        if (( count <= 0 )); then
            SELECTED_INDEX=0
        elif (( SELECTED_INDEX >= count )); then
            SELECTED_INDEX=$((count - 1))
        fi

        write_selected_target
        current_target=$(selected_target)
        if [[ "$current_target" != "$last_target" ]]; then
            update_preview_pane "$current_target"
            last_target="$current_target"
        fi
        render_menu

        key=$(read_key)

        case "$key" in
            $'\x1b[A'|$'\x1bOA')
                (( SELECTED_INDEX > 0 )) && SELECTED_INDEX=$((SELECTED_INDEX - 1))
                ;;
            $'\x1b[B'|$'\x1bOB')
                (( SELECTED_INDEX + 1 < count )) && SELECTED_INDEX=$((SELECTED_INDEX + 1))
                ;;
            $'\x1b')
                read_menu_context
                if [[ "$MENU_CONTEXT" == "language" ]]; then
                    leave_language_menu
                    write_items
                    count=$(item_count)
                elif [[ "$MENU_CONTEXT" == "settings" ]]; then
                    leave_settings_menu
                    write_items
                    count=$(item_count)
                else
                    tmux detach-client -s "$CHOOSER_SESSION" >/dev/null 2>&1
                    exit 0
                fi
                ;;
            $'\x7f'|$'\x08')
                read_menu_context
                if [[ "$MENU_CONTEXT" == "language" ]]; then
                    leave_language_menu
                    write_items
                    count=$(item_count)
                elif [[ "$MENU_CONTEXT" == "settings" ]]; then
                    leave_settings_menu
                    write_items
                    count=$(item_count)
                fi
                ;;
            ''|$'\n'|$'\r')
                handle_enter
                ;;
            n|N)
                handle_create_only
                write_items
                count=$(item_count)
                if (( SELECTED_INDEX >= count )); then
                    SELECTED_INDEX=$((count - 1))
                fi
                write_selected_target
                current_target=$(selected_target)
                update_preview_pane "$current_target"
                last_target="$current_target"
                ;;
            q|Q)
                read_menu_context
                if [[ "$MENU_CONTEXT" == "language" ]]; then
                    leave_language_menu
                    write_items
                    count=$(item_count)
                elif [[ "$MENU_CONTEXT" == "settings" ]]; then
                    leave_settings_menu
                    write_items
                    count=$(item_count)
                else
                    tmux detach-client -s "$CHOOSER_SESSION" >/dev/null 2>&1
                    exit 0
                fi
                ;;
            f|F)
                toggle_favorite
                ;;
            s|S)
                case "$SORT_MODE" in
                    name)    SORT_MODE="created" ;;
                    created) SORT_MODE="attached" ;;
                    *)       SORT_MODE="name" ;;
                esac
                save_config
                ;;
            0)
                _num_idx=9
                _sidx=0
                _lidx=0
                while IFS=$'\t' read -r _kind _rest; do
                    if [[ "$_kind" == "session" ]]; then
                        if (( _sidx == _num_idx )); then
                            SELECTED_INDEX=$_lidx
                            write_selected_target
                            handle_enter
                            break
                        fi
                        _sidx=$(( _sidx + 1 ))
                    fi
                    _lidx=$(( _lidx + 1 ))
                done < "$STATE_DIR/sessions"
                ;;
            [1-9])
                _num_idx=$(( $key - 1 ))
                _sidx=0
                _lidx=0
                while IFS=$'\t' read -r _kind _rest; do
                    if [[ "$_kind" == "session" ]]; then
                        if (( _sidx == _num_idx )); then
                            SELECTED_INDEX=$_lidx
                            write_selected_target
                            handle_enter
                            break
                        fi
                        _sidx=$(( _sidx + 1 ))
                    fi
                    _lidx=$(( _lidx + 1 ))
                done < "$STATE_DIR/sessions"
                ;;
            k|K)
                (( SELECTED_INDEX > 0 )) && SELECTED_INDEX=$((SELECTED_INDEX - 1))
                ;;
            j|J)
                (( SELECTED_INDEX + 1 < count )) && SELECTED_INDEX=$((SELECTED_INDEX + 1))
                ;;
            $'\x12')
                rename_selected_session
                ;;
            $'\x18')
                kill_selected_session
                write_items
                count=$(item_count)
                if (( count == 1 )); then
                    STATUS_MESSAGE="$(status_no_sessions)"
                    SELECTED_INDEX=0
                elif (( SELECTED_INDEX >= count )); then
                    SELECTED_INDEX=$((count - 1))
                fi
                write_selected_target
                current_target=$(selected_target)
                update_preview_pane "$current_target"
                last_target="$current_target"
                ;;
        esac
    done
}

preview_placeholder_mode() {
    ui_init
    clear
    printf '%s%s%s%s\n' "$UI_BOLD" "$UI_BLUE" "$(txt new_title)" "$UI_RESET"
    ui_rule "─"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_action)" "$UI_RESET"
    printf '  %sEnter%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt new_enter_desc)"
    printf '  %sn%s      %s\n' "$UI_BOLD" "$UI_RESET" "$(txt new_n_desc)"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_default)" "$UI_RESET"
    printf '  %s%s%s  %s\n' "$UI_BOLD" "$(txt label_default)" "$UI_RESET" "$(txt default_main)"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_keys)" "$UI_RESET"
    printf '  %sCtrl-R%s   %s\n' "$UI_BOLD" "$UI_RESET" "$(txt rename_desc)"
    printf '  %sCtrl-X%s   %s\n' "$UI_BOLD" "$UI_RESET" "$(txt close_desc)"
    printf '  %sf%s        %s\n' "$UI_BOLD" "$UI_RESET" "$(txt favorite_desc)"
    printf '  %ss%s        %s\n' "$UI_BOLD" "$UI_RESET" "$(txt sort_desc)"
    printf '  %s1-9 / 0%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt number_desc)"
    printf '  %sq / ESC%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt shell_desc)"

    while :; do
        sleep 3600
    done
}

preview_settings_mode() {
    ui_init
    clear
    printf '%s%s%s%s\n' "$UI_BOLD" "$UI_BLUE" "$(txt settings_menu_title)" "$UI_RESET"
    ui_rule "─"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_action)" "$UI_RESET"
    printf '  %sEnter%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt settings_menu_desc)"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_keys)" "$UI_RESET"
    printf '  %sq / ESC%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt back_desc)"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt available)" "$UI_RESET"
    printf '  %s•%s  %s\n' "$UI_CYAN" "$UI_RESET" "$(txt language)"

    while :; do
        sleep 3600
    done
}

preview_language_mode() {
    ui_init
    clear
    printf '%s%s%s%s\n' "$UI_BOLD" "$UI_BLUE" "$(txt language_menu_title)" "$UI_RESET"
    ui_rule "─"
    printf '\n'
    printf '%s%s%s  %s\n' \
        "$UI_BOLD" "$(txt lang_current)" "$UI_RESET" \
        "$(ui_badge "$UI_CYAN" "$(language_display)")"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt available)" "$UI_RESET"
    printf '  %s•%s  de\n' "$UI_CYAN" "$UI_RESET"
    printf '  %s•%s  en\n' "$UI_CYAN" "$UI_RESET"
    printf '  %s•%s  ru\n' "$UI_CYAN" "$UI_RESET"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_action)" "$UI_RESET"
    printf '  %sEnter%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt language_apply)"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_keys)" "$UI_RESET"
    printf '  %sq / ESC%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt back_settings_desc)"

    while :; do
        sleep 3600
    done
}

preview_language_choice_mode() {
    local target_lang="$1"
    local target_name

    ui_init
    clear

    case "$target_lang" in
        de) target_name="$(txt lang_name_de)" ;;
        en) target_name="$(txt lang_name_en)" ;;
        ru) target_name="$(txt lang_name_ru)" ;;
        *) target_name="$target_lang" ;;
    esac

    printf '%s%s%s%s\n' "$UI_BOLD" "$UI_BLUE" "$(txt language_menu_title)" "$UI_RESET"
    ui_rule "─"
    printf '\n'
    printf '%s%s%s  %s\n' \
        "$UI_BOLD" "$(txt language)" "$UI_RESET" \
        "$(ui_badge "$UI_CYAN" "$target_lang")"
    printf '  %s%s%s  %s\n' "$UI_BOLD" "$(txt lang_current)" "$UI_RESET" "$(language_display)"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_action)" "$UI_RESET"
    printf '  %sEnter%s  %s\n' "$UI_BOLD" "$UI_RESET" "$target_name"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_keys)" "$UI_RESET"
    printf '  %sq / ESC%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt back_settings_desc)"

    while :; do
        sleep 3600
    done
}

preview_back_mode() {
    ui_init
    clear
    printf '%s%s%s%s\n' "$UI_BOLD" "$UI_BLUE" "$(txt settings_menu_title)" "$UI_RESET"
    ui_rule "─"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_action)" "$UI_RESET"
    printf '  %sEnter%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt back_desc)"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_keys)" "$UI_RESET"
    printf '  %sq / ESC%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt back_desc)"

    while :; do
        sleep 3600
    done
}

preview_back_settings_mode() {
    ui_init
    clear
    printf '%s%s%s%s\n' "$UI_BOLD" "$UI_BLUE" "$(txt language_menu_title)" "$UI_RESET"
    ui_rule "─"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_action)" "$UI_RESET"
    printf '  %sEnter%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt back_settings_desc)"
    printf '\n'
    printf '%s%s%s\n' "$UI_BOLD" "$(txt section_keys)" "$UI_RESET"
    printf '  %sq / ESC%s  %s\n' "$UI_BOLD" "$UI_RESET" "$(txt back_settings_desc)"

    while :; do
        sleep 3600
    done
}

preview_session_mode() {
    local target="$1"

    unset TMUX
    exec tmux attach-session -r -t "=$target"
}

main_mode() {
    load_config
    STATE_DIR=$(mktemp -d /tmp/tmux-ssh-chooser.XXXXXX)
    CHOOSER_SESSION="${CHOOSER_PREFIX}_$$"

    trap '
        tmux kill-session -t "$CHOOSER_SESSION" >/dev/null 2>&1
        rm -rf "$STATE_DIR"
    ' EXIT HUP INT TERM

    tmux list-sessions -F '#{session_name} #{session_attached}' 2>/dev/null \
        | while IFS=' ' read -r _s _attached; do
            [[ "$_s" == "${CHOOSER_PREFIX}"* ]] && (( _attached == 0 )) && \
                tmux kill-session -t "=$_s" >/dev/null 2>&1
          done

    tmux new-session -d -s "$CHOOSER_SESSION" -n chooser "$(build_mode_command __menu "$STATE_DIR")"
    tmux split-window -h -l 60% -t "$CHOOSER_SESSION":chooser "$(build_mode_command __preview_placeholder "$STATE_DIR")"
    tmux set-option -t "$CHOOSER_SESSION" status off >/dev/null 2>&1
    tmux select-layout -t "$CHOOSER_SESSION":chooser even-horizontal >/dev/null 2>&1
    tmux select-pane -t "$CHOOSER_SESSION":chooser.0 >/dev/null 2>&1
    tmux attach-session -t "$CHOOSER_SESSION"
}

MODE="${1:-__main}"

case "$MODE" in
    __menu)
        STATE_DIR="$2"
        load_config
        menu_mode
        ;;
    __preview_placeholder)
        STATE_DIR="$2"
        load_config
        preview_placeholder_mode
        ;;
    __preview_settings)
        STATE_DIR="$2"
        load_config
        preview_settings_mode
        ;;
    __preview_language)
        STATE_DIR="$2"
        load_config
        preview_language_mode
        ;;
    __preview_language_choice)
        STATE_DIR="$2"
        load_config
        preview_language_choice_mode "$3"
        ;;
    __preview_back)
        STATE_DIR="$2"
        load_config
        preview_back_mode
        ;;
    __preview_back_settings)
        STATE_DIR="$2"
        load_config
        preview_back_settings_mode
        ;;
    __preview_session)
        STATE_DIR="$2"
        load_config
        preview_session_mode "$3"
        ;;
    __main)
        main_mode
        ;;
esac
