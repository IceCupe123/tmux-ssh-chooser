#!/usr/bin/env bash

set -u

CHOOSER_PREFIX="__ssh_chooser"
CHOOSER_SESSION="${TMUX_SSH_CHOOSER_SESSION:-$CHOOSER_PREFIX}"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tmux-ssh-chooser"
CONFIG_FILE="$CONFIG_DIR/config"
CHOOSER_LANG="${TMUX_SSH_CHOOSER_LANG:-de}"
MENU_CONTEXT="root"
FAVORITES=()
SORT_MODE="name"

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck disable=SC1090
        . "$CONFIG_FILE"
    fi

    case "${CHOOSER_LANG:-de}" in
        de|en|ru) ;;
        *) CHOOSER_LANG="de" ;;
    esac

    case "${SORT_MODE:-name}" in
        name|created|attached) ;;
        *) SORT_MODE="name" ;;
    esac
}

save_config() {
    mkdir -p "$CONFIG_DIR"
    {
        printf 'CHOOSER_LANG=%q\n' "$CHOOSER_LANG"
        printf 'SORT_MODE=%q\n'    "$SORT_MODE"
    } > "$CONFIG_FILE"
}

